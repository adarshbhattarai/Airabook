# Copy the values you need into one of the mode-specific files below:
# - .env.localemulator
# - .env.development
# - .env.qa
# - .env.go
# - .env.production
#
# Vite loads the file matching the active mode automatically.

# Primary backend origin used by frontend fetch clients.
VITE_BACKEND_API_URL=

# Optional override when Spring endpoints live on a different origin.
VITE_SPRING_API_URL=

# Optional direct voice websocket URL, e.g. wss://api.example.com/ws/voice
VITE_VOICE_WS_URL=

# Optional HTTP/HTTPS base used to derive the voice websocket URL.
VITE_VOICE_BACKEND_URL=

# Optional local-only fallback if VITE_BACKEND_API_URL is omitted while running on localhost.
VITE_LOCAL_BACKEND_API_URL=http://localhost:8000
