rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function bookDoc(bookId) {
      return firestore.get(/databases/(default)/documents/books/$(bookId));
    }

    function isBookOwnerPath(ownerUid, bookId) {
      let bookData = bookDoc(bookId).data;
      return bookData != null && bookData.ownerId == ownerUid;
    }

    function canManageBookMedia(bookId) {
      let bookData = bookDoc(bookId).data;
      return bookData != null && (
        bookData.ownerId == request.auth.uid ||
        (
          bookData.members != null &&
          bookData.members[request.auth.uid] == 'Owner'
        ) ||
        (
          bookData.members != null &&
          bookData.members[request.auth.uid] == 'Co-author' &&
          bookData.memberPermissions != null &&
          bookData.memberPermissions[request.auth.uid] != null &&
          bookData.memberPermissions[request.auth.uid].canManageMedia == true
        )
      );
    }

    // Book page media and linked album media under the owner's root.
    // This allows:
    // - owner writing to their own path
    // - co-author with canManageMedia writing into the main author's path
    match /{userId}/{bookId}/{chapterId}/{pageId}/media/{mediaType}/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isSignedIn() && (
          request.auth.uid == userId ||
          (
            request.auth.uid != userId &&
            isBookOwnerPath(userId, bookId) &&
            canManageBookMedia(bookId)
          )
        )
      );
      allow delete: if isAdmin();
    }

    // Book-linked album cover path under the owner's root.
    match /{userId}/albums/{albumId}/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isSignedIn() && (
          request.auth.uid == userId ||
          (
            request.auth.uid != userId &&
            isBookOwnerPath(userId, albumId) &&
            canManageBookMedia(albumId)
          )
        )
      );
      allow delete: if isAdmin();
    }

    // Default simplified policy:
    // any signed-in user can write only inside their own {userId}/** root.
    match /{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId
      );
      allow delete: if isAdmin();
    }
  }
}
