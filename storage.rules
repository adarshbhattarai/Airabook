rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function bookDoc(bookId) {
      return firestore.get(/databases/(default)/documents/books/$(bookId));
    }

    function albumDoc(albumId) {
      return firestore.get(/databases/(default)/documents/albums/$(albumId));
    }

    function isOwnUserRoot(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function bookOwnerId(bookId) {
      let bookData = bookDoc(bookId).data;
      return bookData != null
        ? (
          bookData.ownerId != null
            ? bookData.ownerId
            : (
              bookData.members != null &&
              bookData.members[request.auth.uid] == 'Owner'
            )
              ? request.auth.uid
              : null
        )
        : null;
    }

    function albumOwnerId(albumId) {
      let albumData = albumDoc(albumId).data;
      return albumData != null
        ? (
          albumData.accessPermission != null &&
          albumData.accessPermission.ownerId != null
            ? albumData.accessPermission.ownerId
            : albumData.ownerId
        )
        : null;
    }

    function isBookStorageOwner(userId, bookId) {
      let ownerId = bookOwnerId(bookId);
      return ownerId != null && ownerId == userId;
    }

    function isAlbumStorageOwner(userId, albumId) {
      let ownerId = albumOwnerId(albumId);
      return ownerId != null && ownerId == userId;
    }

    function canCurrentUserManageAlbumTarget(albumId) {
      let albumData = albumDoc(albumId).data;
      return albumData != null &&
        (
          (
            albumData.accessPermission != null &&
            albumData.accessPermission.ownerId == request.auth.uid
          ) ||
          (
            albumData.accessPermission != null &&
            albumData.accessPermission.sharedWith != null &&
            request.auth.uid in albumData.accessPermission.sharedWith
          ) ||
          albumData.ownerId == request.auth.uid
        );
    }

    function canCurrentUserManageBookTarget(bookId) {
      let bookData = bookDoc(bookId).data;
      return (
        bookData != null &&
        (
          bookData.ownerId == request.auth.uid ||
          (
            bookData.members != null &&
            bookData.members[request.auth.uid] == 'Owner'
          ) ||
          (
            bookData.members != null &&
            bookData.members[request.auth.uid] == 'Co-author' &&
            bookData.memberPermissions != null &&
            bookData.memberPermissions[request.auth.uid] != null &&
            bookData.memberPermissions[request.auth.uid].canManageMedia == true
          )
        )
      ) ||
        canCurrentUserManageAlbumTarget(bookId);
    }

    function canWriteManagedTargetAtOwnerPath(userId, targetId) {
      return (
        isBookStorageOwner(userId, targetId) &&
        canCurrentUserManageBookTarget(targetId)
      ) || (
        isAlbumStorageOwner(userId, targetId) &&
        canCurrentUserManageAlbumTarget(targetId)
      );
    }

    // Profile avatars:
    //   {uid}/avatars/{file}
    match /{userId}/avatars/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isOwnUserRoot(userId)
      );
      allow delete: if isAdmin();
    }

    // Book covers and pre-create album covers:
    //   {uid}/covers/{file}
    match /{userId}/covers/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isOwnUserRoot(userId)
      );
      allow delete: if isAdmin();
    }

    // Existing album covers:
    //   {uid}/albums/{albumId}/{file}
    match /{userId}/albums/{albumId}/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isSignedIn() &&
        canWriteManagedTargetAtOwnerPath(userId, albumId)
      );
      allow delete: if isAdmin();
    }

    // Page media and album assets:
    //   {uid}/{bookOrAlbumId}/{chapterId}/{pageId}/media/{image|video}/{file}
    // Album-level assets use _album_/_album_ placeholders for chapter/page.
    match /{userId}/{bookOrAlbumId}/{chapterId}/{pageId}/media/{mediaType}/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() || (
        isSignedIn() &&
        canWriteManagedTargetAtOwnerPath(userId, bookOrAlbumId)
      );
      allow delete: if isAdmin();
    }

    // No other client-written Storage paths are currently supported.
    match /{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
