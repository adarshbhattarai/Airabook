rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function bookDoc(bookId) {
      return firestore.get(/databases/(default)/documents/books/$(bookId));
    }

    function bookExists(bookId) {
      return firestore.exists(/databases/(default)/documents/books/$(bookId));
    }

    function albumDoc(albumId) {
      return firestore.get(/databases/(default)/documents/albums/$(albumId));
    }

    function albumExists(albumId) {
      return firestore.exists(/databases/(default)/documents/albums/$(albumId));
    }

    function canWriteBookLinkedAlbumMedia(bookId) {
      return albumExists(bookId) &&
        (
          (
            albumDoc(bookId).data.accessPermission != null &&
            albumDoc(bookId).data.accessPermission.ownerId == request.auth.uid
          ) ||
          (
            albumDoc(bookId).data.accessPermission != null &&
            albumDoc(bookId).data.accessPermission.sharedWith != null &&
            request.auth.uid in albumDoc(bookId).data.accessPermission.sharedWith
          ) ||
          albumDoc(bookId).data.ownerId == request.auth.uid
        );
    }

    function canWriteBookMedia(bookId) {
      return (
        bookExists(bookId) &&
        (
          bookDoc(bookId).data.ownerId == request.auth.uid ||
          (
            bookDoc(bookId).data.members != null &&
            bookDoc(bookId).data.members[request.auth.uid] == 'Owner'
          ) ||
          (
            bookDoc(bookId).data.members != null &&
            bookDoc(bookId).data.members[request.auth.uid] == 'Co-author' &&
            bookDoc(bookId).data.memberPermissions != null &&
            bookDoc(bookId).data.memberPermissions[request.auth.uid] != null &&
            bookDoc(bookId).data.memberPermissions[request.auth.uid].canManageMedia == true
          )
        )
      ) ||
        canWriteBookLinkedAlbumMedia(bookId);
    }

    function canWriteStandaloneAlbumMedia(bookId) {
      return !bookExists(bookId) &&
        albumExists(bookId) &&
        (
          (
            albumDoc(bookId).data.accessPermission != null &&
            albumDoc(bookId).data.accessPermission.ownerId == request.auth.uid
          ) ||
          albumDoc(bookId).data.ownerId == request.auth.uid
        );
    }

    function isMediaPath(path) {
      return path.matches('^[^/]+/[^/]+/[^/]+/media/(image|video)/.*$');
    }

    match /{userId}/{bookId}/{chapterId}/{pageId}/media/{mediaType}/{fileName=**} {
      allow read: if true;
      // Clients can create/update only; delete is server-only via callable/Admin SDK.
      allow create, update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        (canWriteBookMedia(bookId) || canWriteStandaloneAlbumMedia(bookId))
      );
      allow delete: if isAdmin();
    }

    match /{userId}/{allPaths=**} {
      allow read: if true;
      // All non-media paths remain user-writable for create/update only.
      allow create, update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        !isMediaPath(allPaths)
      );
      allow delete: if isAdmin();
    }
  }
}
